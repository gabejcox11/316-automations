  <!-- ============================================================
       JAVASCRIPT
  ============================================================ -->
  <script>
    // ============================================================
    // CONFIGURATION — UPDATE THIS WHEN YOU HAVE YOUR BOOKING LINK
    // ============================================================
    var BOOKING_URL = 'https://calendly.com/gabe-316automations/30min';
    //
    // Once you add your Calendly (or other booking) link above,
    // all "Book a Free Call" buttons on the page will automatically
    // open it in a new tab.
    // ============================================================

    (function () {
      // Wire every booking CTA on the page to BOOKING_URL
      document.querySelectorAll('.nav__cta, .nav__mobile-cta, .btn-primary, .roi-cta-btn, .final-cta__btn, .footer__links a[href="#book-call"]')
        .forEach(function (el) {
          el.href = BOOKING_URL;
          el.target = '_blank';
          el.rel = 'noopener noreferrer';
        });
    })();

    // -------------------------------------------------------
    // Nav: add shadow on scroll
    // -------------------------------------------------------
    (function () {
      var nav = document.getElementById('main-nav');
      if (!nav) return;

      function handleScroll() {
        if (window.scrollY > 10) {
          nav.classList.add('scrolled');
        } else {
          nav.classList.remove('scrolled');
        }
      }

      window.addEventListener('scroll', handleScroll, { passive: true });
    })();


    // -------------------------------------------------------
    // Industry Selector
    // -------------------------------------------------------
    (function () {
      var tabs = document.querySelectorAll('.tab-btn');
      var panels = document.querySelectorAll('.tab-panel');

      if (!tabs.length) return;

      tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          var target = tab.dataset.tab;

          // Update tab buttons
          tabs.forEach(function (t) {
            t.classList.remove('active');
            t.setAttribute('aria-selected', 'false');
          });
          tab.classList.add('active');
          tab.setAttribute('aria-selected', 'true');

          // Update panels
          panels.forEach(function (panel) {
            if (panel.id === 'tab-' + target) {
              panel.classList.add('active');
            } else {
              panel.classList.remove('active');
            }
          });
        });
      });
    })();


    // -------------------------------------------------------
    // ROI Calculator
    // -------------------------------------------------------
    (function () {
      var slider = document.getElementById('missed-calls-slider');
      var sliderDisplay = document.getElementById('slider-display');
      var percentageEl = document.getElementById('roi-percentage');
      var monthlyLostEl = document.getElementById('monthly-lost');
      var monthlyRecoveredEl = document.getElementById('monthly-recovered');

      if (!slider) return;

      var AVG_JOB_VALUE = 600;
      var RECOVERY_RATE = 0.4;
      var ASSUMED_TOTAL_CALLS = 50; // assumed weekly call volume

      function updateROI() {
        var missedPerWeek = parseInt(slider.value, 10);
        var missedPerMonth = missedPerWeek * 4;
        var recoveredPerMonth = Math.round(missedPerMonth * RECOVERY_RATE);
        var monthlyLost = missedPerMonth * AVG_JOB_VALUE;
        var monthlyRecovered = recoveredPerMonth * AVG_JOB_VALUE;
        var pct = Math.round((missedPerWeek / ASSUMED_TOTAL_CALLS) * 100);

        // Update slider background gradient
        var pctFill = ((missedPerWeek - 1) / (20 - 1)) * 100;
        slider.style.background = 'linear-gradient(to right, var(--green) 0%, var(--green) ' + pctFill + '%, var(--border) ' + pctFill + '%, var(--border) 100%)';

        // Update display values
        sliderDisplay.textContent = missedPerWeek;
        percentageEl.innerHTML = 'That\'s roughly <strong>~' + pct + '%</strong> of your calls going unanswered each week.';
        monthlyLostEl.textContent = '$' + monthlyLost.toLocaleString();
        monthlyRecoveredEl.textContent = '$' + monthlyRecovered.toLocaleString() + '/mo';
      }

      slider.addEventListener('input', updateROI);
      updateROI(); // initialize
    })();


    // -------------------------------------------------------
    // FAQ Accordion
    // -------------------------------------------------------
    (function () {
      var faqItems = document.querySelectorAll('.faq-item');

      if (!faqItems.length) return;

      faqItems.forEach(function (item) {
        var trigger = item.querySelector('.faq-trigger');
        var body = item.querySelector('.faq-body');

        if (!trigger || !body) return;

        trigger.addEventListener('click', function () {
          var isOpen = item.classList.contains('open');

          // Close all
          faqItems.forEach(function (i) {
            i.classList.remove('open');
            var b = i.querySelector('.faq-body');
            var t = i.querySelector('.faq-trigger');
            if (b) b.style.maxHeight = null;
            if (t) t.setAttribute('aria-expanded', 'false');
          });

          // Toggle clicked one
          if (!isOpen) {
            item.classList.add('open');
            body.style.maxHeight = body.scrollHeight + 'px';
            trigger.setAttribute('aria-expanded', 'true');
          }
        });
      });
    })();


    // -------------------------------------------------------
    // Timeline: Animate on scroll with IntersectionObserver
    // -------------------------------------------------------
    (function () {
      var nodes = document.querySelectorAll('.timeline-node');
      if (!nodes.length) return;

      if ('IntersectionObserver' in window) {
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
              }
            });
          },
          { threshold: 0.2, rootMargin: '0px 0px -40px 0px' }
        );

        nodes.forEach(function (node) {
          observer.observe(node);
        });
      } else {
        // Fallback for old browsers
        nodes.forEach(function (node) {
          node.classList.add('visible');
        });
      }
    })();
  </script>

</body>
</html>
